    "history_tradition": 1.0,
    "art_sense": 1.0,
    "healing_rest": 1.0
  },
  "reference_tuning_config": {
    "profile_activation_saved_trip_count": 3,
    "alpha_candidates": [
      1.0,
      1.5,
      2.0
    ],
    "weight_range_candidates": [
      {
        "id": "narrow",
        "min": 0.85,
        "max": 1.2
      },
      {
        "id": "medium",
        "min": 0.8,
        "max": 1.3
      },
      {
        "id": "strong",
        "min": 0.7,
        "max": 1.45
      }
    ],
    "profile_score_cap_candidates": [
      0.03,
      0.05,
      0.08
    ],
    "reference_formula": "if saved_trip_count < profile_activation_saved_trip_count: effective_weight[theme] = 1.0 for every theme and profile is inactive; otherwise observed_ratio = saved_theme_counts[theme] / total_saved_theme_count; raw_weight = 1 + alpha * (observed_ratio - 0.2); learned_weight = clamp(raw_weight, min_weight, max_weight); confidence = min(saved_trip_count / profile_activation_saved_trip_count, 1.0); effective_weight = 1 + confidence * (learned_weight - 1)"
  },
