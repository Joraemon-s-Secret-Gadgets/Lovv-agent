flowchart TD
  Client["Client / Backend"] --> Runtime["AWS AgentCore Runtime<br/>LovvAgentCore_LovvAgentV2<br/>READY v3 / Python 3.12 / VPC"]
  Runtime --> Entry["main.py<br/>BedrockAgentCoreApp"]
  Entry --> Handler["handle_v2_invocation<br/>request / thread / actor / resume"]
  Handler --> Harness["build_live_harness<br/>tools + memory + graph"]
  Harness --> Graph["LangGraph V2"]
  Graph --> Supervisor["Supervisor Router<br/>routing.next_node"]

  Supervisor --> Agents["Worker Agents<br/>Intent / Profile / Festival / City<br/>Planner / Explain / Weather / Response"]
  Agents --> Supervisor
  Supervisor --> Response["Final response<br/>or END_WAIT_USER interrupt"]

  Harness --> Deps["AWS dependencies<br/>Bedrock / S3 Vectors / DynamoDB<br/>RDS / ORS / AgentCore Memory"]

