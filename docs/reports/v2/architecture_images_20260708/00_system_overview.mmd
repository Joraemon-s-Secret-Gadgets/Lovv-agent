  classDef runtime fill:#ecfdf5,stroke:#059669,stroke-width:2px,color:#064e3b;
  classDef output fill:#fff7ed,stroke:#ea580c,stroke-width:2px,color:#7c2d12;
  class Runtime,Entry runtime;
  class Handler,Harness,Graph,Supervisor,Agents,Deps core;
