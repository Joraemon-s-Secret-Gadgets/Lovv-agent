%%{init: {"theme": "base", "themeVariables": {"fontFamily": "Inter, Arial, sans-serif", "fontSize": "18px", "primaryColor": "#eef6ff", "primaryBorderColor": "#2563eb", "lineColor": "#475569"}}}%%
flowchart TD
  Itinerary["planner_output.itinerary"] --> Weather["Weather Alternative Agent"]
  Weather --> Exposure["summarize_exposure<br/>indoor / outdoor ratio"]
  Weather --> Risk["WeatherRiskIndex<br/>city_monthly_weather_risks.json"]
  Exposure --> Policy["WeatherDecisionPolicy"]
  Risk --> Policy
  Policy --> Output["weather_audit<br/>user_notice or alternative option"]

  classDef agent fill:#dbeafe,stroke:#2563eb,stroke-width:3px;
  classDef tool fill:#ecfdf5,stroke:#059669,stroke-width:2px;
  classDef output fill:#fff7ed,stroke:#ea580c,stroke-width:2px;
  class Weather agent;
  class Exposure,Risk,Policy tool;
  class Output output;
